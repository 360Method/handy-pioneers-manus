# Analytics — optional. Leave blank to disable.
# GA4 measurement ID (looks like G-XXXXXXXXXX)
VITE_GA4_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID
VITE_META_PIXEL_ID=

# Priority Translation intake (server) — falls back to console log when unset.
RESEND_API_KEY=
INTAKE_RECIPIENT=help@handypioneers.com
UPLOAD_DIR=/tmp/priority-translations
